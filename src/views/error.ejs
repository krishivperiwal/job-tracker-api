<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Error</title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>
  <main class="container">
    <h1>Something went wrong</h1>
    <p><%= message %></p>
    <% if (showStack && stack) { %>
      <pre class="stack"><%= stack %></pre>
    <% } %>
    <a href="/home">Back to Home</a>
  </main>
</body>
</html>